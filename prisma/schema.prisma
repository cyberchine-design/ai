datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  tokenBalance   Int        @default(100000) // Starting budget in tokens
  maxTokenLimit  Int        @default(500000)
  createdAt      DateTime   @default(now())
  sessions       Session[]
  documents      Document[]
}

model Session {
  id        String    @id @default(uuid())
  title     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String   // "user" or "assistant"
  content    String
  tokenCount Int      @default(0)
  audioUrl   String?  // Optional URL to TTS output
  createdAt  DateTime @default(now())
}

model Document {
  id        String   @id @default(uuid())
  filename  String
  filePath  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
